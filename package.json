{
  "name": "posty",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "tsx --env-file=.env worker/index.ts",
    "worker:build": "tsc -p tsconfig.worker.json && tsc-alias -p tsconfig.worker.json",
    "worker:start": "node dist-worker/worker/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "hash-password": "tsx scripts/hash-password.ts",
    "spike:linkedin": "tsx --env-file-if-exists=.env.local scripts/spike-linkedin.ts",
    "migrate:sheets": "tsx --env-file-if-exists=.env.local scripts/migrate-from-sheets.ts",
    "seed:slots": "tsx --env-file-if-exists=.env.local scripts/seed-slots.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.9.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/nodemailer": "^8.0.1",
    "argon2": "^0.41.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^7.0.1",
    "imapflow": "^1.4.7",
    "jose": "^5.9.6",
    "lucide-react": "^0.469.0",
    "luxon": "^3.5.0",
    "mongoose": "^8.9.5",
    "next": "^15.5.20",
    "node-cron": "^3.0.3",
    "nodemailer": "^9.0.3",
    "pdf-lib": "^1.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "satori": "^0.28.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.5.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsc-alias": "^1.9.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.11"
  }
}
