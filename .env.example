# =============================================================================
# Posty — variables d'environnement (union CDC-01 §19 + CDC-02 §14)
# Copie ce fichier en `.env` et remplis les valeurs.
# TOUS les secrets sont attendus sans caractères qui cassent l'interpolation
# shell / docker-compose : privilégie base64 quand tu as le choix.
# =============================================================================

# --- App ---------------------------------------------------------------------
APP_URL=http://localhost:3000
NODE_ENV=development
TZ=Europe/Paris

# Hash argon2id du mot de passe unique, ENCODÉ EN BASE64 (pas de $ dans l'env).
# Génère-le avec : npm run hash-password -- "monMotDePasse"
AUTH_PASSWORD_HASH=

# Secret HS256 pour signer le cookie de session (>= 32 caractères aléatoires).
SESSION_SECRET=

# Clé AES-256-GCM pour chiffrer les tokens LinkedIn au repos (32 octets en base64).
# Génère-la avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# --- Mongo -------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=posty

# --- LinkedIn (§10 CDC-01) ---------------------------------------------------
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/linkedin/callback
LINKEDIN_API_VERSION=202506

# --- Anthropic (§8 CDC-01) ---------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Pushover (§11 CDC-01) ---------------------------------------------------
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=

# --- Assets ------------------------------------------------------------------
ASSETS_DIR=./data/assets

# =============================================================================
# --- Module Mailing (CDC-02)
# =============================================================================

# Twenty CRM (CDC-02 §0 : clé régénérée, JAMAIS en query string, header
# Authorization: Bearer uniquement). Sans ces deux valeurs, /mailing/contacts
# et le ping Twenty renvoient 503.
TWENTY_API_URL=
TWENTY_API_KEY=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=contact@pierre-godino.com

# IMAP
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_ARCHIVE_FOLDER=Posty
